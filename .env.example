# Copy this file to .env and fill in local secrets.
TAVILY_API_KEY=
MINIMAX_API_KEY=
OPENAI_API_KEY=
GITHUB_TOKEN=

# Optional persistent agent memory. Data is local-only and ignored by git.
OFFERGRAPH_MEMORY_ENABLED=true
OFFERGRAPH_MEMORY_DB_PATH=local_data/memory/offergraph_memory.sqlite3
OFFERGRAPH_MEMORY_JSONL_PATH=local_data/memory/events.jsonl

# Local reusable answers for job application forms. Data is local-only and ignored by git.
OFFERGRAPH_JOB_PROFILE_PATH=local_data/job_application/profile.json

# Vendored AI CV Maker project used by the CV tailoring MCP server.
# Personal CV data lives in ignored local_data/.
# Public structure template: templates/cv_maker_user_content
CV_MAKER_PROJECT_ROOT=external/cv_maker
CV_MAKER_USER_CONTENT_DIR=local_data/cv_maker/user_content
# Optional source checkout used only by scripts/sync_cv_maker.py.
# CV_MAKER_SOURCE_PROJECT_ROOT=/path/to/jc-cv-matcher/cv
# CV_MAKER_PYTHON=external/cv_maker/.venv/bin/python
# CV_MAKER_TIMEOUT_SECONDS=900

# Runtime split: CV Maker MCP server and OfferGraph agent run as separate services.
CV_TAILORING_MCP_TRANSPORT=streamable-http
CV_TAILORING_MCP_HOST=127.0.0.1
CV_TAILORING_MCP_PORT=8765
CV_TAILORING_MCP_PATH=/mcp
CV_TAILORING_MCP_URL=http://127.0.0.1:8765/mcp
CV_TAILORING_MCP_CLIENT_TRANSPORT=streamable_http

# Optional model overrides.
# OFFERGRAPH_CONSOLE_MODEL=MiniMax-M2.7
# OFFERGRAPH_PLAN_MASTER_MODEL=MiniMax-M2.7
# OFFERGRAPH_LINKEDIN_MASTER_MODEL=MiniMax-M2.7
# OFFERGRAPH_SEARCH_SUMMARIZER_MODEL=MiniMax-M2.7
# OFFERGRAPH_OPENAI_IMAGE_MODEL=gpt-image-1
