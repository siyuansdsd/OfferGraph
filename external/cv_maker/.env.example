# Copy this file to .env and fill in the keys you want to use.

MINIMAX_API_KEY=
MINIMAX_API_FORMAT=anthropic
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MAX_TOKENS=32768

OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
GITHUB_TOKEN=

CANDIDATE_ADDRESS=
CANDIDATE_WEBSITE=

# rclone destination for daily generated-file archiving.
# Example after `rclone config`: GOOGLE_DRIVE_ARCHIVE_REMOTE=gdrive:CV Maker Archive
GOOGLE_DRIVE_ARCHIVE_REMOTE=

REQUESTS_CA_BUNDLE=
CURL_CA_BUNDLE=
SSL_CERT_FILE=
